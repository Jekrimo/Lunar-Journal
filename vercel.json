{
  "version": 2,
  "functions": {
    "api/*.js": {
      "memory": 256,
      "maxDuration": 30
    }
  },
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/$1.js"
    },
    {
      "src": "/app",
      "dest": "/index.html"
    },
    {
      "src": "/",
      "dest": "/landing.html"
    }
  ]
}
